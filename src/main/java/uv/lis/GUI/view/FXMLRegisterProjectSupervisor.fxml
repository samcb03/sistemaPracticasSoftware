<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="uv.lis.GUI.controller.FXMLRegisterProjectSupervisorController"
           style="-fx-background-color: #F5F4F0;">

    <VBox alignment="CENTER" spacing="16">

        <VBox spacing="12"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-border-color: #E0DED8;
                     -fx-border-width: 0.5;
                     -fx-border-radius: 12;
                     -fx-padding: 40 32 40 32;"
              maxWidth="400"
              minWidth="400">

            <Label text="Registrar Responsable Tecnico"
                   style="-fx-font-size: 20;
                          -fx-font-weight: bold;
                          -fx-text-fill: #1A1A1A;">
                <VBox.margin><Insets bottom="16"/></VBox.margin>
            </Label>

            <Label text="NOMBRE"
                   style="-fx-font-size: 11;
                          -fx-text-fill: #888880;
                          -fx-font-weight: bold;"/>
            <TextField fx:id="textFieldName"
                       promptText="Nombre"
                       style="-fx-background-color: #F5F4F0;
                              -fx-border-color: #C8C6C0;
                              -fx-border-width: 0.5;
                              -fx-border-radius: 8;
                              -fx-background-radius: 8;
                              -fx-font-size: 14;
                              -fx-pref-height: 42;">
                <VBox.margin><Insets bottom="8"/></VBox.margin>
            </TextField>

            <Label text="CARGO"
                   style="-fx-font-size: 11;
                          -fx-text-fill: #888880;
                          -fx-font-weight: bold;"/>
            <TextField fx:id="textFieldPosition"
                       promptText="Cargo"
                       style="-fx-background-color: #F5F4F0;
                              -fx-border-color: #C8C6C0;
                              -fx-border-width: 0.5;
                              -fx-border-radius: 8;
                              -fx-background-radius: 8;
                              -fx-font-size: 14;
                              -fx-pref-height: 42;">
                <VBox.margin><Insets bottom="8"/></VBox.margin>
            </TextField>

            <Label text="CORREO ELECTRONICO"
                   style="-fx-font-size: 11;
                          -fx-text-fill: #888880;
                          -fx-font-weight: bold;"/>
            <TextField fx:id="textFieldEmail"
                       promptText="correo@ejemplo.com"
                       style="-fx-background-color: #F5F4F0;
                              -fx-border-color: #C8C6C0;
                              -fx-border-width: 0.5;
                              -fx-border-radius: 8;
                              -fx-background-radius: 8;
                              -fx-font-size: 14;
                              -fx-pref-height: 42;">
                <VBox.margin><Insets bottom="8"/></VBox.margin>
            </TextField>

            <Label text="ORGANIZACION AFILIADA"
                   style="-fx-font-size: 11;
                          -fx-text-fill: #888880;
                          -fx-font-weight: bold;"/>
            <ComboBox fx:id="comboBoxOrganizationName"
                      promptText="Selecciona una organización"
                      maxWidth="Infinity"
                      style="-fx-font-size: 14;
                             -fx-pref-height: 42;">
                <VBox.margin><Insets bottom="8"/></VBox.margin>
            </ComboBox>

            <Label fx:id="labelError"
                   text=""
                   style="-fx-font-size: 12;
                          -fx-text-fill: red;">
                <VBox.margin><Insets bottom="8"/></VBox.margin>
            </Label>

            <Button text="Registrar"
                    onAction="#validateFields"
                    maxWidth="Infinity"
                    style="-fx-background-color: #87CEEB;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-pref-height: 44;
                           -fx-cursor: hand;"/>

            <Button fx:id="buttonBack"
                    text="Cancelar"
                    onAction="#goBack"
                    maxWidth="Infinity"
                    style="-fx-background-color: #E74C3C;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-pref-height: 44;
                           -fx-cursor: hand;"/>

        </VBox>
    </VBox>
</StackPane>