<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="uv.lis.GUI.controller.FXMLStudentMenuController"
           style="-fx-background-color: #F5F4F0;">

    <VBox alignment="CENTER" spacing="16">

        <VBox spacing="12"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-border-color: #E0DED8;
                     -fx-border-width: 0.5;
                     -fx-border-radius: 12;
                     -fx-padding: 40 32 40 32;"
              maxWidth="360"
              minWidth="360">

            <Label text="Menu Estudiante"
                   style="-fx-font-size: 24;
                          -fx-text-fill: #000000;">
                <VBox.margin><Insets bottom="16"/></VBox.margin>
            </Label>

            <Button fx:id="buttonRequestProject"
                    text="Solicitar Proyecto"
                    onAction="#goToRequestProject"
                    maxWidth="Infinity"
                    style="-fx-background-color: #87CEEB;
                           -fx-text-fill: #ffffff;
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-pref-height: 44;
                           -fx-cursor: hand;"/>

            <Button fx:id="buttonNotifications"
                    text="Notificaciones"
                    onAction="#goToNotifications"
                    maxWidth="Infinity"
                    style="-fx-background-color: #87CEEB;
                           -fx-text-fill: #ffffff;
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-pref-height: 44;
                           -fx-cursor: hand;"/>

              <Button fx:id = "buttonUploadDocuments"
                     text="Subir documentos"
                     onAction="#goToUploadDocuments"
                     maxWidth="Infinity"
                     style="-fx-background-color: #87CEEB;
                            -fx-text-fill: #ffffff;
                            -fx-font-size: 14;
                            -fx-font-weight: bold;
                            -fx-background-radius: 8;
                            -fx-pref-height: 44;
                            -fx-cursor: hand;"/>

            <Separator>
                <VBox.margin><Insets top="8" bottom="8"/></VBox.margin>
            </Separator>

            <Button fx:id="buttonLogOut"
                    text="Cerrar Sesion"
                    onAction="#navigateToLogOut"
                    maxWidth="Infinity"
                    style="-fx-background-color: #E74C3C;
                           -fx-text-fill: #ffffff;
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-pref-height: 44;
                           -fx-cursor: hand;"/>

        </VBox>
    </VBox>
</StackPane>