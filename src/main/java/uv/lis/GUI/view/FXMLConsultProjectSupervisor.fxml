<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="480.0" prefWidth="600.0"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="uv.lis.GUI.controller.FXMLConsultProjectSupervisorController">

    <children>

        <Label layoutY="-1.0" prefHeight="20.0" prefWidth="600.0"
               style="-fx-background-color: orange; -fx-border-color: BLACK;"
               text="Consultar Responsable de Proyecto" />

        <Label layoutX="155.0" layoutY="29.0"
               text="Consultar Responsable de Proyecto">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <Pane layoutX="75.0" layoutY="60.0"
              prefHeight="390.0" prefWidth="450.0"
              style="-fx-background-color: #ffaf9c; -fx-background-radius: 20;">

            <children>

                <TextField fx:id="textFieldNameProjectSupervisor"
                           layoutX="57.0" layoutY="24.0"
                           prefHeight="25.0" prefWidth="279.0"
                           promptText="Escribe el nombre del responsable" />

                <Button fx:id="buttonSearch"
                        layoutX="336.0" layoutY="24.0"
                        mnemonicParsing="false"
                        onAction="#searchProjectSupervisor"
                        text="Buscar" />

                <GridPane fx:id="gridPaneProjectSupervisorInfo"
                          layoutX="57.0" layoutY="62.0"
                          prefHeight="250.0" prefWidth="334.0"
                          visible="false">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES"
                            minWidth="10.0" prefWidth="130.0" />
                        <ColumnConstraints hgrow="SOMETIMES"
                            minWidth="10.0" prefWidth="204.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label text="Nombre:" />
                        <Label text="Cargo:"          GridPane.rowIndex="1" />
                        <Label text="Correo:"         GridPane.rowIndex="2" />
                        <Label text="Organización:"   GridPane.rowIndex="3" />
                        <Label text="Proyecto:"       GridPane.rowIndex="4" />

                        <Label fx:id="labelName"
                               prefHeight="18.0" prefWidth="204.0"
                               GridPane.columnIndex="1" />
                        <Label fx:id="labelPosition"
                               prefHeight="18.0" prefWidth="204.0"
                               GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label fx:id="labelEmail"
                               prefHeight="18.0" prefWidth="204.0"
                               GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Label fx:id="labelOrganization"
                               prefHeight="18.0" prefWidth="204.0"
                               wrapText="true"
                               GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        <Label fx:id="labelProject"
                               prefHeight="18.0" prefWidth="204.0"
                               wrapText="true"
                               GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    </children>
                </GridPane>

                <Label fx:id="labelMessage"
                       layoutX="53.0" layoutY="330.0"
                       prefHeight="17.0" prefWidth="343.0"
                       textAlignment="CENTER" />

                <HBox alignment="CENTER"
                      layoutX="53.0" layoutY="347.0"
                      prefHeight="38.0" prefWidth="343.0"
                      spacing="20.0">
                    <children>
                        <Button fx:id="buttonModify"
                                disable="true"
                                mnemonicParsing="false"
                                text="Modificar" />
                        <Button fx:id="buttonBack"
                                disable="true"
                                mnemonicParsing="false"
                                onAction="#goBack"
                                text="Cancelar" />
                    </children>
                </HBox>

            </children>
        </Pane>

    </children>
</AnchorPane>