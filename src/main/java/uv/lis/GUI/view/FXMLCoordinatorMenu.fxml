<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="583.0" prefWidth="360.0" style="-fx-background-color: #F5F4F0;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uv.lis.GUI.controller.FXMLCoordinatorMenuController">

    <VBox alignment="CENTER" prefWidth="360.0" spacing="16">

        <VBox maxWidth="360" minWidth="360.0" prefHeight="623.0" prefWidth="360.0" spacing="12" style="-fx-background-color: white;                               -fx-background-radius: 12;                               -fx-border-color: #E0DED8;                               -fx-border-width: 0.5;                               -fx-border-radius: 12;                               -fx-padding: 40 32 40 32;">

            <Label style="-fx-font-size: 24;                                        -fx-text-fill: #1A1A1A;" text="Menu Coordinador">
                <VBox.margin><Insets bottom="16" /></VBox.margin>
            </Label>

            <Button fx:id="buttonRegisterStudent" maxWidth="Infinity" onAction="#goToRegisterStudent" style="-fx-background-color: #87CEEB;              -fx-text-fill: #FFFFFF; -fx-font-size: 14;              -fx-font-weight: bold; -fx-background-radius: 8;              -fx-pref-height: 44; -fx-cursor: hand;" text="Registrar Alumno" textFill="WHITE" />

            <Button fx:id="buttonConsultStudent" maxWidth="Infinity" onAction="#goToConsultStudent" style="-fx-background-color: #87CEEB;              -fx-text-fill: #FFFFFF; -fx-font-size: 14;              -fx-font-weight: bold; -fx-background-radius: 8;              -fx-pref-height: 44; -fx-cursor: hand;" text="Consultar Alumno" />
    
            <Button fx:id="buttonRegisterOrganization" maxWidth="Infinity" onAction="#goToRegisterOrganization" style="-fx-background-color: #87CEEB;              -fx-text-fill: #FFFFFF; -fx-font-size: 14;              -fx-font-weight: bold; -fx-background-radius: 8;              -fx-pref-height: 44; -fx-cursor: hand;" text="Registrar Organizacion Vinculada" textFill="WHITE" />
            
            <Button fx:id="buttonConsultOrganization" maxWidth="Infinity" onAction="#goToConsultOrganization" style="-fx-background-color: #87CEEB;              -fx-text-fill: #FFFFFF; -fx-font-size: 14;              -fx-font-weight: bold; -fx-background-radius: 8;              -fx-pref-height: 44; -fx-cursor: hand;" text="Consultar Organizacion Vinculada" />
            
            <Button fx:id="buttonRegisterSupervisor" maxWidth="Infinity" onAction="#goToRegisterSupervisor" style="-fx-background-color: #87CEEB;              -fx-text-fill: #FFFFFF; -fx-font-size: 14;              -fx-font-weight: bold; -fx-background-radius: 8;              -fx-pref-height: 44; -fx-cursor: hand;" text="Registrar Responsable Tecnico" textFill="WHITE" />
            
            <Button fx:id="buttonConsultSupervisor" maxWidth="Infinity" onAction="#goToConsultSupervisor" style="-fx-background-color: #87CEEB;              -fx-text-fill: #FFFFFF; -fx-font-size: 14;              -fx-font-weight: bold; -fx-background-radius: 8;              -fx-pref-height: 44; -fx-cursor: hand;" text="Consultar Responsable Tecnico" />
            
            <Button fx:id="buttonRegisterProject" maxWidth="Infinity" onAction="#goToRegisterProject" style="-fx-background-color: #87CEEB;              -fx-text-fill: #FFFFFF; -fx-font-size: 14;              -fx-font-weight: bold; -fx-background-radius: 8;              -fx-pref-height: 44; -fx-cursor: hand;" text="Registrar Proyecto" textFill="WHITE" />
            
            <Button fx:id="buttonConsultProject" maxWidth="Infinity" onAction="#goToConsultProject" style="-fx-background-color: #87CEEB;              -fx-text-fill: #FFFFFF; -fx-font-size: 14;              -fx-font-weight: bold; -fx-background-radius: 8;              -fx-pref-height: 44; -fx-cursor: hand;" text="Consultar Proyecto" />

        </VBox>
    </VBox>
</StackPane>
