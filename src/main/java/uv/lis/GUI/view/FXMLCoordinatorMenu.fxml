<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="583.0" prefWidth="360.0"
           style="-fx-background-color: #F5F4F0;"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="uv.lis.GUI.controller.FXMLCoordinatorMenuController">

    <VBox alignment="CENTER" prefWidth="360.0" spacing="16">

        <VBox maxWidth="360" minWidth="360.0" spacing="12"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-border-color: #E0DED8;
                     -fx-border-width: 0.5;
                     -fx-border-radius: 12;
                     -fx-padding: 40 32 40 32;">

            <Label text="Menu Coordinador"
                   style="-fx-font-size: 24;
                          -fx-text-fill: #1A1A1A;">
                <VBox.margin><Insets bottom="16"/></VBox.margin>
            </Label>

            <Button fx:id="buttonRegisterStudent"
                    text="Registrar Alumno"
                    onAction="#goToRegisterStudent"
                    maxWidth="Infinity"
                    style="-fx-background-color: #87CEEB;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-pref-height: 44;
                           -fx-cursor: hand;"/>

            <Button fx:id="buttonConsultStudent"
                    text="Consultar Alumno"
                    onAction="#goToConsultStudent"
                    maxWidth="Infinity"
                    style="-fx-background-color: #87CEEB;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-pref-height: 44;
                           -fx-cursor: hand;"/>

            <Button fx:id="buttonRegisterOrganization"
                    text="Registrar Organizacion Vinculada"
                    onAction="#goToRegisterOrganization"
                    maxWidth="Infinity"
                    style="-fx-background-color: #87CEEB;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-pref-height: 44;
                           -fx-cursor: hand;"/>

            <Button fx:id="buttonConsultOrganization"
                    text="Consultar Organizacion Vinculada"
                    onAction="#goToConsultOrganization"
                    maxWidth="Infinity"
                    style="-fx-background-color: #87CEEB;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-pref-height: 44;
                           -fx-cursor: hand;"/>

            <Button fx:id="buttonRegisterSupervisor"
                    text="Registrar Responsable Tecnico"
                    onAction="#goToRegisterSupervisor"
                    maxWidth="Infinity"
                    style="-fx-background-color: #87CEEB;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-pref-height: 44;
                           -fx-cursor: hand;"/>

            <Button fx:id="buttonConsultSupervisor"
                    text="Consultar Responsable Tecnico"
                    onAction="#goToConsultSupervisor"
                    maxWidth="Infinity"
                    style="-fx-background-color: #87CEEB;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-pref-height: 44;
                           -fx-cursor: hand;"/>

            <Button fx:id="buttonRegisterProject"
                    text="Registrar Proyecto"
                    onAction="#goToRegisterProject"
                    maxWidth="Infinity"
                    style="-fx-background-color: #87CEEB;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-pref-height: 44;
                           -fx-cursor: hand;"/>

            <Button fx:id="buttonConsultProject"
                    text="Consultar Proyecto"
                    onAction="#goToConsultProject"
                    maxWidth="Infinity"
                    style="-fx-background-color: #87CEEB;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-pref-height: 44;
                           -fx-cursor: hand;"/>

            <Separator>
                <VBox.margin><Insets top="8" bottom="8"/></VBox.margin>
            </Separator>

            <Button fx:id="buttonLogOut"
                    text="Cerrar Sesion"
                    onAction="#navigateToLogOut"
                    maxWidth="Infinity"
                    style="-fx-background-color: #E74C3C;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-pref-height: 44;
                           -fx-cursor: hand;"/>

        </VBox>
    </VBox>
</StackPane>