<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="510.0" prefWidth="640.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uv.lis.GUI.controller.FXMLConsultStudentExpedientController">

    <children>

        <Label layoutY="-1.0" prefHeight="20.0" prefWidth="640.0" style="-fx-background-color: orange; -fx-border-color: BLACK;" text="Archivos del Alumno" />

        <Label layoutX="215.0" layoutY="29.0" text="Archivos del Alumno">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <Pane layoutX="40.0" layoutY="65.0" prefHeight="425.0" prefWidth="560.0" style="-fx-background-color: #ffaf9c; -fx-background-radius: 20;">

            <children>

                <Label layoutX="25.0" layoutY="20.0" text="Matricula:">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Label>

                <Label fx:id="labelStudentId" layoutX="100.0" layoutY="20.0" prefHeight="18.0" prefWidth="200.0" />

                <Label layoutX="25.0" layoutY="55.0" text="Filtrar por:">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Label>

                <ComboBox fx:id="comboBoxFilter" layoutX="110.0" layoutY="51.0" prefHeight="26.0" prefWidth="200.0" />

                <Label fx:id="labelTotal" layoutX="330.0" layoutY="55.0" prefHeight="18.0" prefWidth="205.0" />

                <TableView fx:id="tableViewArchives" layoutX="25.0" layoutY="90.0" prefHeight="260.0" prefWidth="510.0">
                    <columns>
                        <TableColumn fx:id="columnName" prefWidth="200.0" text="Nombre" />
                        <TableColumn fx:id="columnDocumentType" prefWidth="150.0" text="Tipo de Documento" />
                        <TableColumn fx:id="columnValidated" prefWidth="80.0" text="Validado" />
                        <TableColumn fx:id="columnAction" prefWidth="80.0" text="Acción" />
                    </columns>
                </TableView>

                <Label fx:id="labelMessage" layoutX="25.0" layoutY="360.0" prefHeight="17.0" prefWidth="510.0" textAlignment="CENTER" />

                <HBox alignment="CENTER" layoutX="25.0" layoutY="385.0" prefHeight="35.0" prefWidth="510.0" spacing="20.0">
                    <children>
                        <Button fx:id="buttonBack" mnemonicParsing="false" onAction="#goBack" text="Regresar" />
                    </children>
                </HBox>

            </children>
        </Pane>

    </children>
</AnchorPane>
