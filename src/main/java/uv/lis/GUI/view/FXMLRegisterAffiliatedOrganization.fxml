<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="520.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uv.lis.GUI.controller.FXMLRegisterAffiliatedOrganizationController">
    <children>

            <Label layoutY="-1.0" prefHeight="20.0" prefWidth="600.0" style="-fx-background-color: #a8c8e8; -fx-border-color: BLACK;" text="Registrar Organización Vinculada" />

            <Label layoutX="135.0" layoutY="19.0" text="Registrar Nueva Organización Vinculada"><font><Font name="System Bold" size="20.0" /></font>
            </Label>

            <Pane layoutX="75.0" layoutY="60.0" prefHeight="430.0" prefWidth="450.0" style="-fx-background-color: #cce4f7; -fx-background-radius: 20;">
            <children>

                <Label layoutX="115.0" layoutY="4.0" text="Información de la organización"><font><Font name="System Bold" size="15.0" /></font>
                </Label>

                <Label layoutX="16.0" layoutY="39.0" text="Nombre:"><font><Font size="13.0" /></font>
                </Label>

                <TextField fx:id="textFieldName" layoutX="200.0" layoutY="36.0" prefHeight="25.0" prefWidth="220.0" />

                <Label layoutX="15.0" layoutY="67.0" text="Ciudad:"><font><Font size="13.0" /></font>
                </Label>

                <TextField fx:id="textFieldCity" layoutX="200.0" layoutY="64.0" prefHeight="25.0" prefWidth="220.0" />

                <Label layoutX="16.0" layoutY="97.0" text="Estado:"><font><Font size="13.0" /></font>
                </Label>
                <TextField fx:id="textFieldState" layoutX="200.0" layoutY="94.0" prefHeight="25.0" prefWidth="220.0" />

                <Label layoutX="17.0" layoutY="129.0" text="Sector:"><font><Font size="13.0" /></font>
                </Label>

                <Label layoutX="22.0" layoutY="165.0" text="Calle:"><font><Font size="13.0" /></font>
                </Label>

                <Label layoutX="19.0" layoutY="188.0" text="Número de domicilio:"><font><Font size="13.0" /></font>
                </Label>

                <Label layoutX="17.0" layoutY="215.0" text="Código postal:"><font><Font size="13.0" /></font>
                </Label>

                <TextField fx:id="textFieldPostalCode" layoutX="200.0" layoutY="214.0" prefHeight="25.0" prefWidth="220.0" />
                
                <TextField fx:id="textFieldSector" layoutX="200.0" layoutY="126.0" prefHeight="25.0" prefWidth="220.0" />

                <Label layoutX="15.0" layoutY="251.0" text="Correo electrónico:"><font><Font size="13.0" /></font>
                </Label>

                <TextField fx:id="textFieldEmail" layoutX="200.0" layoutY="248.0" prefHeight="25.0" prefWidth="220.0" />

                <Label layoutX="16.0" layoutY="287.0" text="Teléfono:"><font><Font size="13.0" /></font>
                </Label>

                <TextField fx:id="textFieldPhoneNumber" layoutX="200.0" layoutY="284.0" prefHeight="25.0" prefWidth="220.0" />

                <Label layoutX="14.0" layoutY="322.0" text="Usuarios directos:"><font><Font size="13.0" /></font>
                </Label>

                <TextField fx:id="textFieldNumberOfDirectUsers" layoutX="200.0" layoutY="319.0" prefHeight="25.0" prefWidth="220.0" />

                <Label layoutX="13.0" layoutY="352.0" text="Usuarios indirectos:"><font><Font size="13.0" /></font>
                </Label>

                <TextField fx:id="textFieldNumberOfIndirectUsers" layoutX="200.0" layoutY="349.0" prefHeight="25.0" prefWidth="220.0" />

                <Label fx:id="labelError" layoutX="30.0" layoutY="375.0" prefWidth="390.0" style="-fx-text-fill: red;">
                <font><Font size="11.0" /></font>
                </Label>

                <Button fx:id="buttonRegisterOrganization" layoutX="81.0" layoutY="395.0" mnemonicParsing="false" onAction="#validateFields" prefHeight="28.0" prefWidth="180.0" style="-fx-background-color: white;" text="Registrar Organización" />

                <Button fx:id="buttonBack" layoutX="290.0" layoutY="395.0" mnemonicParsing="false" onAction="#goBack" prefHeight="28.0" prefWidth="80.0" style="-fx-background-color: white;" text="Cancelar" />
      
                <TextField fx:id="textFieldStreet" layoutX="200.0" layoutY="155.0" prefHeight="25.0" prefWidth="220.0" />
      
                <TextField fx:id="textFieldStreetNumber" layoutX="200.0" layoutY="185.0" prefHeight="25.0" prefWidth="220.0" />

            </children>
        </Pane>

    </children>
</AnchorPane>
