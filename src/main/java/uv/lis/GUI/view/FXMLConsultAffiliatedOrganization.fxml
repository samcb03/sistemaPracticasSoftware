<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ContextMenu?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uv.lis.GUI.controller.FXMLConsultAffiliatedOrganizationController">

    <children>

        <Label layoutY="-1.0" prefHeight="20.0" prefWidth="800.0" style="-fx-background-color: orange; -fx-border-color: BLACK;" text="Consultar Organización" />

        <Label fx:id="label" layoutX="250.0" layoutY="29.0" text="Consultar Organización Vinculada">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <Pane layoutX="40.0" layoutY="70.0" prefHeight="500.0" prefWidth="720.0" style="-fx-background-color: #ffaf9c; -fx-background-radius: 20;">

            <children>
                
                <TextField fx:id="textFieldOrganizationName" layoutX="40.0" layoutY="35.0" prefHeight="25.0" prefWidth="350.0" promptText="Escribe el nombre de la organización">
                   <contextMenu>
                      <ContextMenu fx:id="contextMenuSuggestions">
                        <items>
                          <MenuItem mnemonicParsing="false" text="Unspecified Action" />
                        </items>
                      </ContextMenu>
                   </contextMenu>
                </TextField>
                
                <Button fx:id="buttonSearch" layoutX="410.0" layoutY="35.0" mnemonicParsing="false" onAction="#searchAffiliatedOrganization" text="Buscar" />
                
                <GridPane fx:id="gridPaneOrganizationInfo" layoutX="40.0" layoutY="85.0" prefHeight="270.0" prefWidth="350.0">
                  <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" maxWidth="160.0" minWidth="10.0" prefWidth="135.0" />
                    <ColumnConstraints hgrow="SOMETIMES" maxWidth="215.0" minWidth="10.0" prefWidth="215.0" />
                  </columnConstraints>
                  <rowConstraints>
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  </rowConstraints>
                   <children>
                      <Label text="Nombre:" />
                      <Label text="Ciudad:" GridPane.rowIndex="1" />
                      <Label text="Estado:" GridPane.rowIndex="2" />
                      <Label text="Sector:" GridPane.rowIndex="3" />
                      <Label text="Correo:" GridPane.rowIndex="4" />
                      <Label text="Teléfono:" GridPane.rowIndex="5" />
                      <Label text="Usuarios Directos:" GridPane.rowIndex="6" />
                      <Label text="Usuarios Indirectos:" GridPane.rowIndex="7" />
                      <Label text="Estado actual:" GridPane.rowIndex="8" />
                      
                      <Label fx:id="labelName" prefHeight="18.0" prefWidth="215.0" GridPane.columnIndex="1" />
                      <Label fx:id="labelCity" prefHeight="18.0" prefWidth="215.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                      <Label fx:id="labelState" prefHeight="18.0" prefWidth="215.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                      <Label fx:id="labelSector" prefHeight="18.0" prefWidth="215.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                      <Label fx:id="labelEmail" prefHeight="18.0" prefWidth="215.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                      <Label fx:id="labelPhoneNumber" prefHeight="18.0" prefWidth="215.0" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                      <Label fx:id="labelNumberOfDirectUsers" prefHeight="18.0" prefWidth="215.0" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                      <Label fx:id="labelNumberOfIndirectUsers" prefHeight="18.0" prefWidth="215.0" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                      <Label fx:id="labelStatus" prefHeight="18.0" prefWidth="215.0" GridPane.columnIndex="1" GridPane.rowIndex="8" />
                   </children>
                </GridPane>

                <Label layoutX="410.0" layoutY="85.0" text="Proyectos Asociados:">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                </Label>
                <ListView fx:id="listViewProjects" layoutX="410.0" layoutY="110.0" prefHeight="245.0" prefWidth="270.0" />
                
                <Label fx:id="labelMessage" alignment="CENTER" layoutX="40.0" layoutY="385.0" prefHeight="17.0" prefWidth="640.0" textAlignment="CENTER" />
                
                <HBox alignment="CENTER" layoutX="40.0" layoutY="420.0" prefHeight="38.0" prefWidth="640.0" spacing="30.0">
                   <children>
                      <Button fx:id="buttonUpdate" mnemonicParsing="false" text="Actualizar" />
                      <Button fx:id="buttonInactive" mnemonicParsing="false" text="Inactivar" />
                      <Button fx:id="buttonBack" mnemonicParsing="false" onAction="#goBack" text="Cancelar" />
                   </children>
                </HBox>

            </children>
        </Pane>

    </children>
</AnchorPane>