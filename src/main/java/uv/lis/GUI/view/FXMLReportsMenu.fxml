<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="340.0" prefWidth="360.0" style="-fx-background-color: #F5F4F0;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uv.lis.GUI.controller.FXMLReportsMenuController">

    <VBox alignment="CENTER" prefWidth="360.0" spacing="16">

        <VBox maxWidth="360" minWidth="360.0" spacing="12" style="-fx-background-color: white;                      -fx-background-radius: 12;                      -fx-border-color: #E0DED8;                      -fx-border-width: 0.5;                      -fx-border-radius: 12;                      -fx-padding: 40 32 40 32;">

            <Label style="-fx-font-size: 24; -fx-text-fill: #1A1A1A;" text="Generar Reporte">
                <VBox.margin><Insets bottom="16" /></VBox.margin>
            </Label>

            <Button fx:id="buttonGenerateMonthlyReport" maxWidth="Infinity" onAction="#goToGenerateMonthlyReport" style="-fx-background-color: #87CEEB;                            -fx-text-fill: #FFFFFF;                            -fx-font-size: 14;                            -fx-font-weight: bold;                            -fx-background-radius: 8;                            -fx-pref-height: 44;                            -fx-cursor: hand;" text="Reporte Mensual" />

            <Button fx:id="buttonGeneratePartialReport" maxWidth="Infinity" onAction="#goToGeneratePartialReport" style="-fx-background-color: #87CEEB;                            -fx-text-fill: #FFFFFF;                            -fx-font-size: 14;                            -fx-font-weight: bold;                            -fx-background-radius: 8;                            -fx-pref-height: 44;                            -fx-cursor: hand;" text="Reporte Parcial" />
         <Button fx:id="buttonGenerateFinalReport" maxWidth="Infinity" onAction="#goToGenerateFinalReport" style="-fx-background-color: #87CEEB;                            -fx-text-fill: #FFFFFF;                            -fx-font-size: 14;                            -fx-font-weight: bold;                            -fx-background-radius: 8;                            -fx-pref-height: 44;                            -fx-cursor: hand;" text="Reporte Final" />

            <Separator>
                <VBox.margin><Insets bottom="8" top="8" /></VBox.margin>
            </Separator>

            <Button fx:id="buttonBack" maxWidth="Infinity" onAction="#goBack" style="-fx-background-color: #E74C3C;                            -fx-text-fill: #FFFFFF;                            -fx-font-size: 14;                            -fx-font-weight: bold;                            -fx-background-radius: 8;                            -fx-pref-height: 44;                            -fx-cursor: hand;" text="Cancelar" />

        </VBox>
    </VBox>
</StackPane>
