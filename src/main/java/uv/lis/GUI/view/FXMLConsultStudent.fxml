<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ContextMenu?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="480.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uv.lis.GUI.controller.FXMLConsultStudentController">

    <children>

        <Label layoutY="-1.0" prefHeight="20.0" prefWidth="600.0" style="-fx-background-color: orange; -fx-border-color: BLACK;" text="Consultar Alumno" />

        <Label layoutX="215.0" layoutY="29.0" text="Consultar Alumno">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <Pane layoutX="75.0" layoutY="60.0" prefHeight="390.0" prefWidth="450.0" style="-fx-background-color: #ffaf9c; -fx-background-radius: 20;">

            <children>
            <TextField fx:id="textFieldStudentId" layoutX="57.0" layoutY="46.0" prefHeight="25.0" prefWidth="279.0" promptText="Escribe una matricula">
               <contextMenu>
                  <ContextMenu fx:id="contextMenuSuggestions">
                    <items>
                      <MenuItem mnemonicParsing="false" text="Unspecified Action" />
                    </items>
                  </ContextMenu>
               </contextMenu></TextField>
            <Button fx:id="buttonSearch" layoutX="336.0" layoutY="46.0" mnemonicParsing="false" onAction="#searchStudent" text="Buscar" />
            <GridPane fx:id="gridPaneStudentInfo" layoutX="57.0" layoutY="81.0" prefHeight="239.0" prefWidth="334.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="162.20001220703125" minWidth="10.0" prefWidth="119.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="215.0" minWidth="10.0" prefWidth="215.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Label text="Matricula:" />
                  <Label text="Nombre(s):" GridPane.rowIndex="1" />
                  <Label text="Apellidos:" GridPane.rowIndex="2" />
                  <Label text="Fecha de Nacimiento:" GridPane.rowIndex="3" />
                  <Label text="Genero:" GridPane.rowIndex="4" />
                  <Label fx:id="labelStudentId" prefHeight="18.0" prefWidth="213.0" GridPane.columnIndex="1" />
                  <Label fx:id="labelFirstName" prefHeight="18.0" prefWidth="216.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label fx:id="labelLastName" prefHeight="18.0" prefWidth="215.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <Label fx:id="labelDateBirth" prefHeight="18.0" prefWidth="216.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                  <Label fx:id="labelGender" prefHeight="18.0" prefWidth="220.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                  <Label text="Experiencia Educativa:" GridPane.rowIndex="5" />
                  <Label text="Proyecto Asignado:" GridPane.rowIndex="6" />
                  <Label fx:id="labelSubject" prefHeight="18.0" prefWidth="224.0" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                  <Label fx:id="labelProject" prefHeight="18.0" prefWidth="245.0" GridPane.columnIndex="1" GridPane.rowIndex="6" />
               </children>
            </GridPane>
            <HBox alignment="CENTER" layoutX="53.0" layoutY="339.0" prefHeight="38.0" prefWidth="343.0" spacing="20.0">
               <children>
                  <Button fx:id="buttonUpdate" mnemonicParsing="false" text="Actualizar" />
                  <Button fx:id="buttonInactivate" mnemonicParsing="false" onAction="#inactivateStudent" text="Inactivar" />
                  <Button fx:id="buttonBack" mnemonicParsing="false" onAction="#goBack" text="Cancelar" />
               </children>
            </HBox>
            <Label fx:id="labelMessage" layoutX="53.0" layoutY="322.0" prefHeight="17.0" prefWidth="343.0" textAlignment="CENTER" />

            </children>
        </Pane>

    </children>
</AnchorPane>
