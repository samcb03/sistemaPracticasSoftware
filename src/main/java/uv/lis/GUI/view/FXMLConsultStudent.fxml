<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ContextMenu?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="480.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uv.lis.GUI.controller.FXMLConsultStudentController">

  <children>

    <Label layoutY="-1.0" prefHeight="20.0" prefWidth="600.0" style="-fx-background-color: orange; -fx-border-color: BLACK;" text="Consultar Alumno" />

    <Label layoutX="215.0" layoutY="29.0" text="Consultar Alumno">
      <font><Font name="System Bold" size="20.0" /></font>
    </Label>

    <Pane layoutX="75.0" layoutY="59.0" prefHeight="390.0" prefWidth="450.0" style="-fx-background-color: #ffaf9c; -fx-background-radius: 20;">
      <children>

        <TextField fx:id="textFieldStudentId" layoutX="57.0" layoutY="21.0" prefHeight="25.0" prefWidth="279.0" promptText="Escribe una matricula">
          <contextMenu>
            <ContextMenu fx:id="contextMenuSuggestions">
              <items>
                <MenuItem mnemonicParsing="false" text="Unspecified Action" />
              </items>
            </ContextMenu>
          </contextMenu>
        </TextField>

        <Button fx:id="buttonSearch" layoutX="336.0" layoutY="21.0" mnemonicParsing="false" onAction="#searchStudent" text="Buscar" />

        <TabPane fx:id="tabPaneStudent" blendMode="SRC_ATOP" layoutX="14.0" layoutY="56.0" prefHeight="265.0" prefWidth="415.0" style="-fx-border-color: #ffaf9c;" tabClosingPolicy="UNAVAILABLE">

          <Tab text="Información Personal">
            <content>
              <GridPane prefHeight="200.0" prefWidth="334.0">
                <columnConstraints>
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="130.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
                </columnConstraints>
                <rowConstraints>
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                </rowConstraints>
                <children>
                  <Label text="Matricula:" />
                  <Label text="Nombre(s):" GridPane.rowIndex="1" />
                  <Label text="Apellidos:" GridPane.rowIndex="2" />
                  <Label text="Fecha de Nacimiento:" GridPane.rowIndex="3" />
                  <Label text="Genero:" GridPane.rowIndex="4" />

                  <Label fx:id="labelStudentId" prefWidth="198.0" GridPane.columnIndex="1" />
                  <Label fx:id="labelFirstName" prefWidth="198.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label fx:id="labelLastName" prefWidth="198.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <Label fx:id="labelDateBirth" prefWidth="198.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                  <Label fx:id="labelGender" prefWidth="198.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                  <TextField fx:id="textFieldName" managed="false" visible="false" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <TextField fx:id="textFieldLastName" managed="false" visible="false" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <DatePicker fx:id="datePickerBirthDate" managed="false" prefWidth="191.0" visible="false" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                  <ComboBox fx:id="comboBoxGender" managed="false" prefWidth="190.0" visible="false" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                </children>
              </GridPane>
            </content>
          </Tab>

          <Tab text="Información Escolar">
                  <content>
                     <VBox prefHeight="67.0" prefWidth="414.0">
                        <children>
                    <GridPane prefHeight="178.0" prefWidth="414.0">
                      <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="180.0" />
                      </columnConstraints>
                      <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                 <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                 <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                      </rowConstraints>
                      <children>
                        <Label text="Experiencia Educativa:" />
                        <Label text="Proyecto Asignado:" GridPane.rowIndex="1" />
                        <Label text="Estado:" GridPane.rowIndex="2" />
         
                              <Label fx:id="labelSubject" prefWidth="178.0" wrapText="true" GridPane.columnIndex="1" />
                        <Label fx:id="labelProject" prefWidth="178.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label fx:id="labelIsInactive" prefWidth="178.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                 <Label text="Horas Completadas:" GridPane.rowIndex="3" />
                                 <Label fx:id="labelCompletedHours" prefHeight="18.0" prefWidth="226.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                 <Label text="Actividades Asignadas:" GridPane.rowIndex="4" />
                      </children>
                    </GridPane>
                           <TableView fx:id="tableViewActivityDetails" prefHeight="200.0" prefWidth="200.0">
                             <columns>
                               <TableColumn fx:id="tableColumnActivityName" prefWidth="87.20000916719437" text="Actividad" />
                               <TableColumn fx:id="tableColumnActivityDescription" prefWidth="162.4000244140625" text="Descripcion" />
                                 <TableColumn fx:id="tableColumnActivityStartDate" prefWidth="80.00001525878906" text="Fecha Inicio" />
                                 <TableColumn fx:id="tableColumnActivityEndDate" prefWidth="89.60003662109375" text="Fecha Fin" />
                             </columns>
                           </TableView>
                        </children>
                     </VBox>
                  </content>
          </Tab>

        </TabPane>

        <HBox alignment="CENTER" layoutX="53.0" layoutY="339.0" prefHeight="38.0" prefWidth="343.0" spacing="20.0">
          <children>
            <Button fx:id="buttonUpdate" mnemonicParsing="false" onAction="#enableEditMode" text="Actualizar" />
            <Button fx:id="buttonSave" managed="false" mnemonicParsing="false" onAction="#saveStudent" text="Guardar" visible="false" />
            <Button fx:id="buttonInactivate" mnemonicParsing="false" onAction="#inactivateStudent" text="Inactivar" />
            <Button fx:id="buttonBack" mnemonicParsing="false" onAction="#goBack" text="Cancelar" />
          </children>
        </HBox>

        <Label fx:id="labelMessage" layoutX="53.0" layoutY="322.0" prefHeight="17.0" prefWidth="343.0" textAlignment="CENTER" />

      </children>
    </Pane>

  </children>
</AnchorPane>
