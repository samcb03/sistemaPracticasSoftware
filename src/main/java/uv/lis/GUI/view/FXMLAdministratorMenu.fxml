<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane style="-fx-background-color: #F5F4F0;"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="uv.lis.GUI.controller.FXMLAdministratorMenuController">

    <VBox alignment="CENTER" spacing="16">

        <VBox maxWidth="360" minWidth="360" spacing="12"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-border-color: #E0DED8;
                     -fx-border-width: 0.5;
                     -fx-border-radius: 12;
                     -fx-padding: 40 32 40 32;">

            <Label text="Menu Administrador"
                   style="-fx-font-size: 24;
                          -fx-text-fill: #1A1A1A;">
                <VBox.margin><Insets bottom="16"/></VBox.margin>
            </Label>

            <Button fx:id="buttonRegisterProfessor"
                    text="Registrar Profesor"
                    onAction="#goToRegisterProfessor"
                    maxWidth="Infinity"
                    style="-fx-background-color: #87CEEB;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-pref-height: 44;
                           -fx-cursor: hand;"/>

            <Button fx:id="buttonConsultProfessor"
                    text="Consultar Profesor"
                    onAction="#goToConsultProfessor"
                    maxWidth="Infinity"
                    style="-fx-background-color: #87CEEB;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-pref-height: 44;
                           -fx-cursor: hand;"/>

            <Button fx:id="buttonRegisterSchoolPeriod"
                    text="Registrar Periodo Escolar"
                    onAction="#goToRegisterSchoolPeriod"
                    maxWidth="Infinity"
                    style="-fx-background-color: #87CEEB;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-pref-height: 44;
                           -fx-cursor: hand;"/>

            <Separator>
                <VBox.margin><Insets top="8" bottom="8"/></VBox.margin>
            </Separator>

            <Button fx:id="buttonLogOut"
                    text="Cerrar Sesion"
                    onAction="#navigateToLogOut"
                    maxWidth="Infinity"
                    style="-fx-background-color: #E74C3C;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-pref-height: 44;
                           -fx-cursor: hand;"/>

        </VBox>
    </VBox>
</StackPane>