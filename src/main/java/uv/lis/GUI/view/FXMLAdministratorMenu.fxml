<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane style="-fx-background-color: #F5F4F0;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uv.lis.GUI.controller.FXMLAdministratorMenuController">

    <VBox alignment="CENTER" spacing="16">

        <VBox maxWidth="360" minWidth="360" spacing="12" style="-fx-background-color: white;                               -fx-background-radius: 12;                               -fx-border-color: #E0DED8;                               -fx-border-width: 0.5;                               -fx-border-radius: 12;                               -fx-padding: 40 32 40 32;">

            <Label style="-fx-font-size: 24;                                        -fx-text-fill: #1A1A1A;" text="Menu Administrador">
                <VBox.margin><Insets bottom="16" /></VBox.margin>
            </Label>

            <Button fx:id="buttonRegisterProfessor" maxWidth="Infinity" onAction="#goToRegisterProfessor" style="-fx-background-color: #87CEEB;              -fx-text-fill: #FFFFFF; -fx-font-size: 14;              -fx-font-weight: bold; -fx-background-radius: 8;              -fx-pref-height: 44; -fx-cursor: hand;" text="Registrar Profesor" textFill="WHITE" />

            <Button fx:id="buttonModifyProfessor" maxWidth="Infinity" onAction="#goToModifyProfessor" style="-fx-background-color: #87CEEB;              -fx-text-fill: #FFFFFF; -fx-font-size: 14;              -fx-font-weight: bold; -fx-background-radius: 8;              -fx-pref-height: 44; -fx-cursor: hand;" text="Modificar Profesor" />

            <Button fx:id="buttonInactivateProfessor" maxWidth="Infinity" onAction="#goToInactivateProfessor" style="-fx-background-color: #87CEEB;              -fx-text-fill: #FFFFFF; -fx-font-size: 14;              -fx-font-weight: bold; -fx-background-radius: 8;              -fx-pref-height: 44; -fx-cursor: hand;" text="Inactivar Profesor" textFill="WHITE" />

        </VBox>
    </VBox>
</StackPane>
