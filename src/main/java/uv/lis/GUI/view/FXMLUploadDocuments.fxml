<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="480.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uv.lis.GUI.controller.FXMLUploadDocumentsController">
    <children>

        <Label layoutY="-1.0" prefHeight="20.0" prefWidth="600.0" style="-fx-background-color: orange; -fx-border-color: BLACK;" text=" Sistema de Expedientes" />

        <Label layoutX="150.0" layoutY="29.0" text="Subir Documento al Expediente">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <Pane layoutX="75.0" layoutY="60.0" prefHeight="390.0" prefWidth="450.0" style="-fx-background-color: #87CEEB; -fx-background-radius: 20;">
            <children>

                <Label layoutX="120.0" layoutY="21.0" text="Información del Documento">
                    <font>
                        <Font name="System Bold" size="15.0" />
                    </font>
                </Label>

                <Label layoutX="30.0" layoutY="60.0" text="Tipo de Documento:">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Label>
                <ComboBox fx:id="comboBoxDocuments" layoutX="158.0" layoutY="57.0" prefHeight="25.0" prefWidth="250.0" />

                <Label fx:id="labelError" layoutX="30.0" layoutY="324.0" prefWidth="390.0" style="-fx-text-fill: red;" wrapText="true">
                    <font>
                        <Font size="11.0" />
                    </font>
                </Label>

                <Button fx:id="buttonUploadDocument" layoutX="85.0" layoutY="348.0" mnemonicParsing="false" onAction="#uploadDocument" prefHeight="28.0" prefWidth="146.0" style="-fx-background-color: white;" text="Seleccionar Archivo" />

              <Button fx:id="buttonBack" layoutX="276.0" layoutY="350.0" mnemonicParsing="false" onAction="#goBack" prefHeight="18.0" prefWidth="62.0" style="-fx-background-color: white;" text="Cancelar" />
            <TableView fx:id="tableViewFiles" layoutX="30.0" layoutY="106.0" prefHeight="200.0" prefWidth="390.0">
              <columns>
                <TableColumn fx:id="tableColumnFiles" prefWidth="120.0" text="Archivos Subidos" />
                  <TableColumn fx:id="tableColumnType" prefWidth="110.0" text="Tipo" />
                  <TableColumn fx:id="tableColumnState" prefWidth="90.0" text="Estado" />
                  <TableColumn fx:id="tableColumnAction" prefWidth="70.0" text="Acción" />
              </columns>
            </TableView>

            </children>
        </Pane>

    </children>
</AnchorPane>
