<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<StackPane style="-fx-background-color: #F5F4F0;" 
xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" 
fx:controller="uv.lis.GUI.controller.FXMLLoginController">

    <VBox alignment="CENTER" spacing="0">

        <VBox maxWidth="360" minWidth="360" spacing="0" style="-fx-background-color: white;                      
        -fx-background-radius: 12;                     
        -fx-border-color: #E0DED8;                     
        -fx-border-width: 0.5;                      
        -fx-border-radius: 12;                      
        -fx-padding: 40 32 40 32;">

            <Label style="-fx-font-size: 24;                           
            -fx-text-fill: #1A1A1A;" text="Inicia sesion">
            <VBox.margin><Insets bottom="4" /></VBox.margin>
            </Label>

            <Label style="-fx-font-size: 13;                           
            -fx-text-fill: #888880;" text="Introduce tus credenciales para continuar">
            <VBox.margin><Insets bottom="28" /></VBox.margin>
            </Label>

            <Label style="-fx-font-size: 11;                           
            -fx-text-fill: #888880;-fx-font-weight: bold;" text="CORREO ELECTRÓNICO">
            <VBox.margin><Insets bottom="6" /></VBox.margin>
            </Label>

            <TextField fx:id="textFieldEmail" promptText="Correo electrónico" style="-fx-background-color: #F5F4F0;                               
            -fx-border-color: #C8C6C0;                               
            -fx-border-width: 0.5;                               
            -fx-border-radius: 8;                               
            -fx-background-radius: 8;                               
            -fx-font-size: 14;                               
            -fx-pref-height: 42;">
            <VBox.margin><Insets bottom="16" /></VBox.margin>
            </TextField>

            <Label style="-fx-font-size: 11;                           
            -fx-text-fill: #888880;                           
            -fx-font-weight: bold;" text="CONTRASEÑA">
            <VBox.margin><Insets bottom="6" /></VBox.margin>
            </Label>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox.margin><Insets bottom="24" /></VBox.margin>

                <StackPane HBox.hgrow="ALWAYS">

                <PasswordField fx:id="passwordFieldPassword" promptText="********" style="-fx-background-color: #F5F4F0;                                   
                -fx-border-color: #C8C6C0;                                   
                -fx-border-width: 0.5;                                   
                -fx-border-radius: 8;                                   
                -fx-background-radius: 8;                                   
                -fx-font-size: 14;                                   
                -fx-pref-height: 42;">
                <VBox.margin><Insets bottom="24" /></VBox.margin>
                </PasswordField>

                <TextField fx:id="textFieldPasswordVisible" visible="false" style="-fx-background-color: #F5F4F0;
                    -fx-border-color: #C8C6C0;                                   
                        -fx-border-width: 0.5;                                   
                        -fx-border-radius: 8;                                   
                        -fx-background-radius: 8;                                   
                        -fx-font-size: 14;                                   
                        -fx-pref-height: 42;" />
                </StackPane>

                <ToggleButton fx:id="toggleButtonShowPassword" mnemonicParsing="false" 
                onAction="#togglePasswordVisibility" style="-fx-background-color: transparent; -fx-cursor: hand;">
                <graphic>
                        <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../imagens/show-password-icon-eye-symbol-vision-hide-from-watch-icon-secret-view-web-design-element-vector1.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </ToggleButton>
            </HBox>

            <Label fx:id="labelError" style="-fx-font-size: 12;                           
            -fx-text-fill: red;" text="">
            <VBox.margin><Insets bottom="12" /></VBox.margin>
            </Label>

            <Button fx:id="buttonLogin" maxWidth="Infinity" onAction="#handleLogin" style="-fx-background-color: #87CEEB; -fx-text-fill: #ffffff; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 8; -fx-pref-height: 44; -fx-cursor: hand;" text="Iniciar sesion" textFill="WHITE" />
        </VBox>
    </VBox>
</StackPane>