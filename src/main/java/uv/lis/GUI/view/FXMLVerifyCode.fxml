<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane style="-fx-background-color: #F5F4F0;"
    xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="uv.lis.GUI.controller.FXMLVerifyCodeController">

    <VBox alignment="CENTER" spacing="0">

        <VBox maxWidth="360" minWidth="360" spacing="0" style="-fx-background-color: white;
        -fx-background-radius: 12;
        -fx-border-color: #E0DED8;
        -fx-border-width: 0.5;
        -fx-border-radius: 12;
        -fx-padding: 40 32 40 32;">

            <Label style="-fx-font-size: 24; -fx-text-fill: #1A1A1A;"
                text="Verificación en dos pasos">
                <VBox.margin><Insets bottom="4" /></VBox.margin>
            </Label>

            <Label style="-fx-font-size: 13; -fx-text-fill: #888880;"
                text="Ingresa el código que enviamos a tu correo">
                <VBox.margin><Insets bottom="28" /></VBox.margin>
            </Label>

            <Label style="-fx-font-size: 11; -fx-text-fill: #888880; -fx-font-weight: bold;"
                text="CÓDIGO DE VERIFICACIÓN">
                <VBox.margin><Insets bottom="6" /></VBox.margin>
            </Label>

            <TextField fx:id="textFieldCode" promptText="000000" style="-fx-background-color: #F5F4F0;
            -fx-border-color: #C8C6C0;
            -fx-border-width: 0.5;
            -fx-border-radius: 8;
            -fx-background-radius: 8;
            -fx-font-size: 14;
            -fx-pref-height: 42;">
                <VBox.margin><Insets bottom="16" /></VBox.margin>
            </TextField>

            <CheckBox fx:id="checkBoxDisableEmailAuthentication"
                text="No volver a solicitar autenticación por correo"
                style="-fx-font-size: 12; -fx-text-fill: #555550;">
                <VBox.margin><Insets bottom="16" /></VBox.margin>
            </CheckBox>

            <Label fx:id="labelMessage" style="-fx-font-size: 12; -fx-text-fill: red;" text="">
                <VBox.margin><Insets bottom="12" /></VBox.margin>
            </Label>

            <Button fx:id="buttonVerify" maxWidth="Infinity" onAction="#handleVerify"
                style="-fx-background-color: #87CEEB; -fx-text-fill: #ffffff; -fx-font-size: 14;
                -fx-font-weight: bold; -fx-background-radius: 8; -fx-pref-height: 44; -fx-cursor: hand;"
                text="Verificar" textFill="WHITE" />
        </VBox>
    </VBox>
</StackPane>