<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="480.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uv.lis.GUI.controller.FXMLRegisterSubjectController">

    <children>

        <Label layoutY="-1.0" prefHeight="20.0" prefWidth="600.0" style="-fx-background-color: orange; -fx-border-color: BLACK;" text="Registrar EE" />

        <Label layoutX="153.0" layoutY="29.0" text="Registrar Experiencia Educativa">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <Pane layoutX="75.0" layoutY="60.0" prefHeight="390.0" prefWidth="450.0" style="-fx-background-color: #ffaf9c; -fx-background-radius: 20;">

            <children>

                <Label layoutX="172.0" layoutY="14.0" text="Informacion EE">
                    <font>
                        <Font name="System Bold" size="15.0" />
                    </font>
                </Label>

                <Label layoutX="30.0" layoutY="60.0" text="NRC:" />
                <TextField fx:id="textFieldNRC" layoutX="160.0" layoutY="57.0" prefHeight="25.0" prefWidth="250.0" />

                <Label layoutX="30.0" layoutY="100.0" text="Experiencia Educativa:" />

                <Label layoutX="28.0" layoutY="178.0" text="Periodo:" />

                <Label layoutX="30.0" layoutY="223.0" text="Profesor:" />
                <ComboBox fx:id="comboBoxProfessorName" layoutX="160.0" layoutY="219.0" prefHeight="25.0" prefWidth="250.0" />

                <Label fx:id="labelMessage" layoutX="30.0" layoutY="284.0" prefWidth="390.0" style="-fx-text-fill: red;">
                    <font>
                        <Font size="11.0" />
                    </font>
                </Label>

                <Button fx:id="buttonRegister" layoutX="73.0" layoutY="309.0" mnemonicParsing="false" onAction="#validateFields" prefHeight="28.0" prefWidth="146.0" style="-fx-background-color: white;" text="Registrar EE" />

                <Button fx:id="buttonBack" layoutX="274.0" layoutY="309.0" mnemonicParsing="false" onAction="#goBack" prefHeight="28.0" prefWidth="146.0" style="-fx-background-color: white;" text="Cancelar" />
            <Label layoutX="29.0" layoutY="141.0" text="Carrera:" />
            <Label fx:id="labelSubject" layoutX="160.0" layoutY="98.0" prefHeight="21.0" prefWidth="250.0" />
            <Label fx:id="labelCareer" layoutX="160.0" layoutY="139.0" prefHeight="21.0" prefWidth="250.0" />
            <ComboBox fx:id="comboBoxPeriodName" layoutX="160.0" layoutY="174.0" prefHeight="25.0" prefWidth="250.0" />
            <Label layoutX="29.0" layoutY="275.0" text="Sección" />
            <ComboBox fx:id="comboBoxSection" layoutX="160.0" layoutY="262.0" prefHeight="25.0" prefWidth="250.0" />

            </children>
        </Pane>

    </children>
</AnchorPane>
